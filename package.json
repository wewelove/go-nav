{
  "name": "go-nav",
  "version": "1.6.0",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "next dev",
    "dev:static": "BUILD_MODE=static next dev",
    "build": "pnpm run build:server",
    "build:server": "BUILD_MODE=server next build --webpack && node scripts/copy-standalone-assets.mjs",
    "build:static": "BUILD_MODE=static node scripts/sync-uploads.mjs && BUILD_MODE=static next build --webpack && node -e \"const fs=require('fs'),p=require('path');const d=p.join(process.cwd(),'public','uploads');if(fs.existsSync(d))fs.rmSync(d,{recursive:true,force:true});console.log('[build:static] 已清理 public/uploads/')\"",
    "start": "node .next/standalone/server.js",
    "lint": "eslint",
    "docker:build": "sh scripts/docker-build.sh",
    "docker:up": "docker compose up -d --build",
    "docker:logs": "docker compose logs -f",
    "docker:down": "docker compose down",
    "docker:run": "docker run --rm -p 3000:3000 -e ADMIN_USER=admin -e ADMIN_PASS=admin123 -v \"$PWD/go-nav-data:/app/data\" go-nav:latest",
    "docker:push": "sh scripts/docker-push.sh"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroui/react": "^3.0.5",
    "@heroui/styles": "^3.0.5",
    "@iconify/react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "fetch-jsonp": "^1.4.0",
    "jotai": "^2.20.0",
    "jotai-family": "^1.0.2",
    "next": "16.3.0-canary.19",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-icons": "^5.6.0",
    "sharp": "^0.34.5",
    "terser-webpack-plugin": "^5.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^10",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^6"
  }
}